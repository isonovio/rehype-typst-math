{
  "name": "rehype-typst-math",
  "version": "0.1.0",
  "description": "rehype plugin to render inline and block math in Typst syntax to MathML",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "hast-util-from-html": "^2.0.0",
    "unist-util-visit": "^5.0.0"
  },
  "peerDependencies": {
    "unified": ">=11"
  },
  "devDependencies": {
    "@types/hast": "^3.0.0",
    "@types/node": "^22.0.0",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.0.0",
    "rehype-stringify": "^10.0.0",
    "typescript": "^5.0.0",
    "unified": "^11.0.0"
  },
  "keywords": [
    "rehype",
    "unified",
    "typst",
    "math",
    "mathml",
    "markdown"
  ],
  "license": "MIT"
}
